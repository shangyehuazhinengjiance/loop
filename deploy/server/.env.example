# 复制为 .env 后修改：cp .env.example .env

# ── 镜像 ─────────────────────────────────────────────
LOOP_IMAGE_TAG=local
NODE_IMAGE=node:22-alpine

# ── 对外端口（宿主机）──────────────────────────────
ORCHESTRATOR_PUBLISH_PORT=3000
GATEWAY_PUBLISH_PORT=3001
WEB_PUBLISH_PORT=3002

# ── 前端构建时写入的公网地址（改域名后需重新 build web）──
# 直连端口示例：
NEXT_PUBLIC_ORCHESTRATOR_URL=http://YOUR_SERVER_IP:3000
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP:3001
# 若前面有 Nginx 反代（见 nginx.loop.conf.example），改为：
# NEXT_PUBLIC_ORCHESTRATOR_URL=https://loop.example.com/api
# NEXT_PUBLIC_WS_URL=wss://loop.example.com

# ── 数据库（必填）──────────────────────────────────
# 使用本机 compose 内置 MySQL 时（--profile local-db）：
# DATABASE_URL=mysql://loop:loop@mysql:3306/loop
# 使用公司/自建 MySQL 时：
DATABASE_URL=mysql://USER:PASSWORD@MYSQL_HOST:3306/loop
DB_TIMEZONE=+08:00

# 仅 local-db profile 使用：
MYSQL_ROOT_PASSWORD=loop_root
MYSQL_DATABASE=loop
MYSQL_USER=loop
MYSQL_PASSWORD=loop
MYSQL_PUBLISH_PORT=3306
MYSQL_DATA_PATH=./data/mysql

# ── 模型 API Key（必填）────────────────────────────
PM_MODEL_API_KEY=
DEV_MODEL_API_KEY=
OPS_MODEL_API_KEY=

PM_MODEL_BASE_URL=https://api.anthropic.com
PM_MODEL_NAME=claude-sonnet-4-20250514
DEV_MODEL_BASE_URL=https://api.360.cn
DEV_MODEL_NAME=google/gemini-2.5-pro
DEV_AGENT_RUNTIME=client-sdk
OPS_MODEL_BASE_URL=https://api.anthropic.com
OPS_MODEL_NAME=claude-sonnet-4-20250514

# ── Orchestrator ───────────────────────────────────
ORCHESTRATOR_PORT=3000
WORKSPACE_ROOT=/data/workspaces
WORKSPACE_HOST_PATH=./data/workspaces

GIT_DEFAULT_REMOTE_URL=git@github.com:your-org/your-repo.git
GIT_DEFAULT_BRANCH=master
GIT_DEFAULT_CREDENTIAL_REF=GIT_SSH_KEY_PATH
GIT_SSH_KEY_PATH=/secrets/git/id_ed25519
GIT_SSH_KEY_HOST_PATH=./data/git-secrets
# HTTPS 可选：GIT_ACCESS_TOKEN=

# ── Gateway / Web ──────────────────────────────────
WS_PORT=3001
PORT=3002
HOSTNAME=0.0.0.0
