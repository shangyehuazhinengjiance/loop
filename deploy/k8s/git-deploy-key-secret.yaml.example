# GitHub Deploy Key 私钥（仅 Orchestrator clone/push 用）
#
# 1. 本机生成密钥对（若还没有）：
#      ssh-keygen -t ed25519 -C "loop-orchestrator" -f loop-deploy-key -N ""
# 2. GitHub 仓库 → Settings → Deploy keys → Add deploy key
#      Title: loop-orchestrator
#      Key: 粘贴 loop-deploy-key.pub 内容
#      若 Dev 验收后需 push 分支，勾选 Allow write access
# 3. 创建 Secret：
#      cp git-deploy-key-secret.yaml.example git-deploy-key-secret.yaml
#      # 将 id_ed25519 文件内容填入下方（保留换行）
#      kubectl apply -f git-deploy-key-secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: loop-git-deploy-key
  namespace: loop
type: Opaque
stringData:
  id_ed25519: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    PASTE_YOUR_PRIVATE_KEY_HERE
    -----END OPENSSH PRIVATE KEY-----
