# 复制为 secret.yaml 并填入真实值，不要提交到 Git
#   cp secret.yaml.example secret.yaml
#   kubectl apply -f secret.yaml
#
# 或使用公司密钥平台 / External Secrets Operator 注入

apiVersion: v1
kind: Secret
metadata:
  name: loop-secrets
  namespace: loop
type: Opaque
stringData:
  # 公司 PostgreSQL（必填）
  DATABASE_URL: "postgresql://USER:PASSWORD@PG_HOST:5432/loop?sslmode=require"

  # 模型 API Key（必填）
  PM_MODEL_API_KEY: "your-pm-api-key"
  DEV_MODEL_API_KEY: "your-dev-api-key"
  OPS_MODEL_API_KEY: "your-ops-api-key"

  # 私有 Git（可选，二选一）
  GIT_ACCESS_TOKEN: ""
  # GIT_SSH_KEY_PATH 在 K8s 中建议改为挂载 Secret 卷，见 orchestrator-deployment.yaml 注释

  # LiteLLM（可选）
  # LITELLM_API_KEY: ""
