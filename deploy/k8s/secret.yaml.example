# 复制为 secret.yaml 并填入真实值，不要提交到 Git
#   cp secret.yaml.example secret.yaml
#   kubectl apply -f secret.yaml
#
# 或使用公司密钥平台 / External Secrets Operator 注入

apiVersion: v1
kind: Secret
metadata:
  name: loop-secrets
  namespace: loop
type: Opaque
stringData:
  # 公司 MySQL（必填）
  DATABASE_URL: "mysql://USER:PASSWORD@MYSQL_HOST:3306/loop"

  # 模型 API Key（必填）
  PM_MODEL_API_KEY: "your-pm-api-key"
  DEV_MODEL_API_KEY: "your-dev-api-key"
  OPS_MODEL_API_KEY: "your-ops-api-key"

  # GitHub PAT / GitLab Token：clone/push 可用 SSH，但创建 MR/PR 必须配置此项（与 Deploy Key 并存）
  # GitHub：Settings → Developer settings → PAT，勾选 repo（含 pull requests）
  GIT_ACCESS_TOKEN: ""

  # LiteLLM（可选）
  # LITELLM_API_KEY: ""
