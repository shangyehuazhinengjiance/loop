{
  "name": "ai-native-loop",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/agents/*",
    "packages/orchestrator-v2",
    "packages/agent-worker"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:orchestrator": "npm run dev -w @loop/orchestrator",
    "dev:orchestrator-v2": "npm run dev -w @loop/orchestrator-v2",
    "dev:agent-worker": "npm run dev -w @loop/agent-worker",
    "dev:gateway": "npm run dev -w @loop/gateway",
    "dev:web": "npm run dev -w @loop/web",
    "db:migrate": "npm run migrate -w @loop/orchestrator",
    "db:migrate:v2": "npm run migrate -w @loop/orchestrator-v2",
    "docker:build": "bash scripts/build-images.sh",
    "docker:compose:v2": "docker compose -f docker-compose.v2.yml up -d --build",
    "test": "npm run test --workspaces --if-present",
    "e2e": "powershell -File scripts/e2e-smoke.ps1",
    "lockfile:sync": "node scripts/sync-lockfile.mjs",
    "clean:build": "node scripts/cleanup-build-artifacts.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
