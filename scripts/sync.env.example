# GitHub → GitLab 镜像同步配置
# 复制为 sync.env 并填入真实值，不要提交到 Git
#   cp sync.env.example sync.env

# GitHub 源（只读）
GITHUB_REPO_URL=https://github.com/shangyehuazhinengjiance/loop.git
# 私有仓库时填 PAT（只需 repo 读权限）
GITHUB_TOKEN=

# GitLab 目标（写权限）
GITLAB_REPO_URL=https://code.geelib.qihoo.net:12443/ai-native/loop.git
# GitLab Personal Access Token 或 Deploy Token（需 write_repository）
GITLAB_TOKEN=

# 本地镜像工作目录（脚本会 clone/fetch 到这里）
SYNC_WORK_DIR=/var/lib/loop-mirror

# 要同步的分支（空格分隔，留空则同步 GitHub 上所有远程分支）
SYNC_BRANCHES="master main test"

# 是否同步 tags
SYNC_TAGS=true

# 日志目录
SYNC_LOG_DIR=/var/log/loop-sync
