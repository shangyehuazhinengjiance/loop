# 数据库
DATABASE_URL=mysql://loop:loop@localhost:3306/loop

# Orchestrator
ORCHESTRATOR_PORT=3000
ORCHESTRATOR_URL=http://localhost:3000

# Gateway
WS_PORT=3001

# Web UI
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# PM Agent 模型
PM_MODEL_BASE_URL=https://api.anthropic.com
PM_MODEL_API_KEY=
PM_MODEL_NAME=claude-sonnet-4-20250514

# Dev Agent 模型（OpenAI 兼容，支持 Gemini / DeepSeek 等）
DEV_MODEL_BASE_URL=https://api.openai.com
DEV_MODEL_API_KEY=
DEV_MODEL_NAME=gpt-4o
# client-sdk（默认）= OpenAI 工具循环；agent-sdk = Claude Code（仅 Claude）
DEV_AGENT_RUNTIME=client-sdk
# DEV_AGENT_MAX_TURNS=30

# Ops Agent 模型
OPS_MODEL_BASE_URL=https://api.anthropic.com
OPS_MODEL_API_KEY=
OPS_MODEL_NAME=claude-sonnet-4-20250514

# LiteLLM 网关（可选）
# LITELLM_PROXY_URL=http://localhost:4000/v1
# LITELLM_API_KEY=sk-loop-litellm

# Ops MCP 服务器（JSON，可选）
# OPS_MCP_SERVERS={"deploy":{"command":"npx","args":["-y","@modelcontextprotocol/server-everything"]}}

# Git 凭证（可并存：SSH 用于 clone/push，Token 用于创建 MR/PR）
GIT_SSH_KEY_PATH=
GIT_ACCESS_TOKEN=
# GIT_MR_CREDENTIAL_REF=GIT_ACCESS_TOKEN

# 默认 Git 仓库（创建 Project 时自动 clone 到工作区，供 Dev Agent 使用）
GIT_DEFAULT_REMOTE_URL=git@github.com:your-org/your-repo.git
GIT_DEFAULT_BRANCH=main
GIT_DEFAULT_CREDENTIAL_REF=GIT_SSH_KEY_PATH

# 工作区
WORKSPACE_ROOT=./workspaces

# clone 后自动生成代码库摘要（.loop/codebase-summary.md），设为 false 可关闭
# CODEBASE_SUMMARY_ENABLED=true

# 项目需求文档总结（进入 Loop 时 PM 阅读；Loop 完成时自动更新）
# REQUIREMENTS_SUMMARY_ENABLED=true

# 沙箱（docker = 每 Loop Docker 隔离模式标记）
# SANDBOX_MODE=docker
# SANDBOX_IMAGE=node:20-bookworm

# PM Agent（client-sdk = OpenAI 兼容；agent-sdk = Anthropic SDK，仅 Claude）
# PM_AGENT_RUNTIME=client-sdk
# PM_MODEL_BASE_URL=https://api.360.cn
# PM_MODEL_NAME=google/gemini-2.5-pro
# PM_MODEL_API_KEY=
# PM_AGENT_DEBUG=true

# Dev Agent（agent-sdk / Claude Code 模式）调试与权限
# DEV_AGENT_DEBUG=true
# DEV_PERMISSION_MODE=default

# Ops Agent（client-sdk = OpenAI 兼容；agent-sdk = Claude Code，仅 Claude 模型）
# OPS_AGENT_RUNTIME=client-sdk
# OPS_MODEL_BASE_URL=https://api.360.cn
# OPS_MODEL_NAME=google/gemini-2.5-pro
# OPS_MODEL_API_KEY=
# OPS_AGENT_DEBUG=true

# Docker 基础镜像（业务 Dockerfile 的 --build-arg，与 Harbor 中 loop-base-* 一致）
# BASE_REGISTRY=harbor.qihoo.net/syhzqfw-sjxm-ai-native
# BASE_TAG=latest

# 部署阶段：创建 loop/{id} → test 的 MR，合并后 @ 人跑流水线（不启动 Ops LLM）
# DEPLOY_TARGET_BRANCH=test
# DEPLOY_MERGE_SKILLS=运维 合并 MR 代码评审
# DEPLOY_PIPELINE_SKILLS=运维 CI 流水线 K8s
# 创建 MR 需 GIT_ACCESS_TOKEN（GitHub/GitLab API）；企业版可设：
# GITHUB_API_BASE=https://github.example.com/api/v3
# GITLAB_API_BASE=https://gitlab.example.com/api/v4

# Ops Agent（仅 @ops-agent 手动触发时使用；阶段进入 deployment 不再自动跑）
# OPS_ALLOW_PROD=0

# 阻塞超时提醒间隔（小时，0 关闭）
# BLOCKER_REMINDER_HOURS=24
