# =============================================================================
# AI Native Loop — Web 镜像（Next.js）
# =============================================================================
#   docker build -f Dockerfile.web \
#     --build-arg BASE_REGISTRY=harbor.qihoo.net/syhzqfw-sjxm-ai-native \
#     --build-arg BASE_TAG=latest \
#     --build-arg NEXT_PUBLIC_ORCHESTRATOR_URL=https://api.example.com \
#     --build-arg NEXT_PUBLIC_WS_URL=wss://ws.example.com \
#     -t loop-web .
# =============================================================================

ARG BASE_REGISTRY=harbor.qihoo.net/syhzqfw-sjxm-ai-native
ARG BASE_TAG=latest

FROM ${BASE_REGISTRY}/loop-base-web-builder:${BASE_TAG} AS builder

WORKDIR /app/packages/web

ARG NEXT_PUBLIC_ORCHESTRATOR_URL=http://api.test.loop.qihoo.net/
ARG NEXT_PUBLIC_WS_URL=ws://api.test.loop.qihoo.net:3001

ENV NEXT_PUBLIC_ORCHESTRATOR_URL=$NEXT_PUBLIC_ORCHESTRATOR_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL

COPY packages/web ./

RUN npm run build

FROM harbor.qihoo.net/library/node:22.16.0-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3002
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

COPY --from=builder /app/packages/web/public ./packages/web/public
COPY --from=builder --chown=nextjs:nodejs /app/packages/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/packages/web/.next/static ./packages/web/.next/static

USER nextjs

EXPOSE 3002

CMD ["node", "packages/web/server.js"]
