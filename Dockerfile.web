# syntax=docker/dockerfile:1.4
# Web — 仓库根目录构建: DOCKER_BUILDKIT=1 docker build -f Dockerfile.web -t loop-web .

FROM harbor.qihoo.net/library/node:22.16.0-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_ORCHESTRATOR_URL=http://api.test.loop.qihoo.net/
ARG NEXT_PUBLIC_WS_URL=ws://api.test.loop.qihoo.net:3001

ENV NEXT_PUBLIC_ORCHESTRATOR_URL=$NEXT_PUBLIC_ORCHESTRATOR_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL

COPY package.json package-lock.json ./
COPY packages/web ./packages/web

# public 目录可能为空，确保存在以免 runner 阶段 COPY 失败
RUN mkdir -p packages/web/public

RUN --mount=type=cache,target=/root/.npm \
    npm install
RUN npm run build -w @loop/web

FROM harbor.qihoo.net/library/node:22.16.0-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3002
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

COPY --from=builder /app/packages/web/public ./packages/web/public
COPY --from=builder --chown=nextjs:nodejs /app/packages/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/packages/web/.next/static ./packages/web/.next/static

USER nextjs

EXPOSE 3002

CMD ["node", "packages/web/server.js"]
